# GROQ API Configuration
GROQ_API_KEY=<your-api-key>

# GROQ API base URL must use the OpenAI-compatible endpoint.
# The legacy groq.ai endpoint is no longer valid.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Model Routing
PRIMARY_MODEL=anthropic/claude-opus-4.1
SECONDARY_MODEL=anthropic/claude-sonnet-4
FAST_MODEL=google/gemini-2.5-flash
FALLBACK_MODEL=google/gemini-2.5-pro
